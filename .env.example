# Trading Diary 环境变量模板
# 复制为 .env 并修改实际值：cp .env.example .env
# .env 属性会覆盖 application.yml 中的同名属性

# === 数据库 ===
spring.datasource.url=jdbc:mysql://localhost:3306/trading_diary?useSSL=true&serverTimezone=UTC&characterEncoding=UTF-8
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver
spring.datasource.username=root
spring.datasource.password=your_password_here

# === JWT（必须设置，至少 32 字节随机字符串）===
app.jwt.secret=PLEASE_CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_AT_LEAST_32_BYTES

# === 管理员初始化（必须设置强密码）===
app.init.admin-password=PLEASE_SET_A_STRONG_ADMIN_PASSWORD
