# Trading Diary 环境变量模板
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# === 数据库 ===
DB_URL=jdbc:mysql://localhost:3306/trading_diary
DB_USERNAME=root
DB_PASSWORD=your_password_here

# === JWT ===
# dev 环境有默认值，prod 必须设置
JWT_SECRET=change-me-to-a-random-secret-at-least-256-bits

# === 管理员初始化 ===
# 首次启动时创建的管理员密码
ADMIN_INIT_PASSWORD=admin123
